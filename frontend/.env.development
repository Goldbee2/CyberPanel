HTTPS=true
SSL_CRT_FILE=./certificate/certificate.pem
SSL_KEY_FILE=./certificate/key.pem

# Backend API (no trailing slash). Override in .env.development.local for LAN / other hosts.
REACT_APP_API_BASE_URL=https://localhost:9000
# Must match backend FRONTEND_ORIGIN in APIKeys.env when testing OAuth on LAN.
REACT_APP_FRONTEND_ORIGIN=https://localhost:3000
